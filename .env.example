# Imperium of Man — environment variables
# Copy to ~/.config/imperium-of-man/env.sh (or sourced in shell rc) on each machine.
# Adeptus Mechanicus MCP plugin reads these at MCP server startup.

# --- Jira (Atlassian) ---
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
export ATLASSIAN_SITE_NAME="your-site"
export ATLASSIAN_USER_EMAIL="you@example.com"
export ATLASSIAN_API_TOKEN="ATATT3xFfGF0..."

# --- New Relic ---
# Generate at: https://one.newrelic.com/api-keys (User key)
export NEW_RELIC_API_KEY="NRAK-..."

# --- NotebookLM ---
# No token needed (uses local browser auth via notebooklm-mcp).
# Run `npx notebooklm-mcp@latest setup` once per machine.
